# Образец окружения. Скопировать в .env и заполнить секреты.
# cp .env.example .env

# OpenRouter (LLM генерация ответа)
# Ключ получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Выбрана по A/B 2026-07-12 (см. open-questions.md): полнее и грамотнее альтернативы
# google/gemma-4-31b-it на инструкциях 1С. Платный эндпоинт (без :free): бесплатные
# держат общую очередь и часами отдают 429. Расход мизерный - $0.09/$1.10 за 1M токенов,
# вопрос пилота стоит доли цента.
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PostgreSQL (docker-compose)
POSTGRES_USER=usprings
POSTGRES_PASSWORD=usprings
POSTGRES_DB=usprings_rag
# Если 5432 занят (локальный Postgres) - смените порт и обновите его в DATABASE_URL.
POSTGRES_PORT=5432

# Подключение приложения к БД (SQLAlchemy, драйвер psycopg v3)
DATABASE_URL=postgresql+psycopg://usprings:usprings@localhost:5432/usprings_rag

# Эмбеддинги
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Чанкинг и поиск (CHUNK_* и TOP_K - стартовые значения)
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=64
TOP_K=5
# Откалибровано на eval 2026-07-12 (25 вопросов, recall@1 = 17/17):
# пропускает все релевантные (min 0.5477), режет все вне-доменные (max 0.5209).
# Околодоменные непокрытые 1С-вопросы (0.52-0.56) частично проходят - их закрывает
# промпт этапа 6 ("нет в контексте - скажи, что информации нет"). См. open-questions.md.
SIMILARITY_THRESHOLD=0.53

# Генерация ответа
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800

# Аутентификация и сессии (MVP1)
# SECRET_KEY подписывает cookie-сессии. Задать длинной случайной строкой
# (напр. python -c "import secrets; print(secrets.token_urlsafe(48))").
# Пусто - dev-режим: эфемерный ключ, перезапуск разлогинит всех.
SECRET_KEY=change-me-long-random-string
SESSION_COOKIE_NAME=usprings_session
SESSION_MAX_AGE=86400
# Бутстрап super-admin при ПЕРВОМ старте (пустая таблица users). После создания
# учётки эти переменные можно убрать; пароль сменить в профиле.
SUPERADMIN_LOGIN=admin
SUPERADMIN_PASSWORD=change-me
# Усечение вопроса/ответа в списках истории и аналитике (в самой записи - полный текст).
QUERY_LOG_PREVIEW_CHARS=160
# Фоновый воркер индексации загруженных из UI PDF (в процессе приложения).
# false - инстанс только отвечает и не индексирует.
INDEX_WORKER_ENABLED=true
