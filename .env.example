# Образец окружения. Скопировать в .env и заполнить секреты.
# cp .env.example .env

# OpenRouter (LLM генерация ответа)
# Ключ получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Бесплатная модель по умолчанию для MVP (мультиязычная, русский).
# Альтернатива для сравнения на калибровке: google/gemma-4-31b-it:free
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PostgreSQL (docker-compose)
POSTGRES_USER=usprings
POSTGRES_PASSWORD=usprings
POSTGRES_DB=usprings_rag
# Если 5432 занят (локальный Postgres) - смените порт и обновите его в DATABASE_URL.
POSTGRES_PORT=5432

# Подключение приложения к БД (SQLAlchemy, драйвер psycopg v3)
DATABASE_URL=postgresql+psycopg://usprings:usprings@localhost:5432/usprings_rag

# Эмбеддинги
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Чанкинг и поиск (CHUNK_* и TOP_K - стартовые значения)
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=64
TOP_K=5
# Откалибровано на eval 2026-07-12 (25 вопросов, recall@1 = 17/17):
# пропускает все релевантные (min 0.5477), режет все вне-доменные (max 0.5209).
# Околодоменные непокрытые 1С-вопросы (0.52-0.56) частично проходят - их закрывает
# промпт этапа 6 ("нет в контексте - скажи, что информации нет"). См. open-questions.md.
SIMILARITY_THRESHOLD=0.53

# Генерация ответа
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
